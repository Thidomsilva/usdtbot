{
  "version": 2,
  "builds": [
    {
      "src": "usdt-tracker/frontend/package.json",
      "use": "@vercel/next"
    },
    {
      "src": "usdt-tracker/api/index.py",
      "use": "@vercel/python",
      "config": {
        "runtime": "python3.12",
        "maxDuration": 15
      }
    }
  ],
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/usdt-tracker/api/index.py" }
  ]
}
